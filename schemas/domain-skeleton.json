{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "domain-skeleton",
  "type": "object",
  "required": ["domain", "categories", "fields"],
  "properties": {
    "domain": { "type": "string" },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "name"],
        "properties": {
          "slug": { "type": "string" },
          "name": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "categories"],
        "properties": {
          "name":       { "type": "string" },
          "type":       { "type": "string" },
          "categories": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
